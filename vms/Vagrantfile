# -*- mode: ruby -*-
# vi: set ft=ruby :

# Get number of students from environment variable or use default
NUM_STUDENTS = (ENV['NUM_STUDENTS'] || '1').to_i

# Validate number of students
if NUM_STUDENTS < 1 || NUM_STUDENTS > 253  # Keep 254 as max to avoid conflicts
  puts "Error: Number of students must be between 1 and 253"
  exit 1
end

# Define a Node class to encapsulate node properties
class Node
  attr_reader :role, :box, :mac, :ip
  
  def initialize(role, box, mac, ip)
    @role = role
    @box = box
    @mac = mac
    @ip = ip
  end

  def to_dhcp_entry
    %(<host mac='#{@mac}' name='#{@role}' ip='#{@ip}'/>)
  end

  # Generate nodes for given number of students
  def self.generate_nodes(num_students)
    (1..num_students).map do |id|
      student_num = id + 1  # Start student numbers at 02
      ip_num = id + 1      # Start IPs at .2
      mac = format("00:00:00:00:00:%02x", ip_num)
      ip = "192.198.254.#{ip_num}"
      new("student#{format('%02d', student_num)}", "debian/bookworm64", mac, ip)
    end
  end
end

# Network configuration - TODO: this should come from inventory files
NETWORK_CONFIG = {
  name: 'studentnet',
  bridge: 'virbr10',
  mac: 'AA:AA:AA:AA:AA:AA',
  ip: '192.198.254.1',
  netmask: '255.255.255.0',
  dhcp_range: {
    start: '192.198.254.2',
    end: '192.198.254.253'
  }
}

# Generate nodes based on NUM_STUDENTS
NODES = Node.generate_nodes(NUM_STUDENTS)

# Common VM configuration
NODE_CPUS = 2
NODE_MEMORY = 2048

# Generate network XML from configuration
def generate_network_xml(network_config, nodes)
  <<-EOF
<network>
  <name>#{network_config[:name]}</name>
  <forward mode='nat'>
    <nat>
      <port start='1024' end='65535'/>
    </nat>
  </forward>
  <bridge name='#{network_config[:bridge]}' stp='on' delay='0'/>
  <mac address='#{network_config[:mac]}'/>
  <ip address='#{network_config[:ip]}' netmask='#{network_config[:netmask]}'>
    <dhcp>
      <range start='#{network_config[:dhcp_range][:start]}' end='#{network_config[:dhcp_range][:end]}'/>
      #{nodes.map(&:to_dhcp_entry).join("\n      ")}
    </dhcp>
  </ip>
</network>
  EOF
end

Vagrant.configure("2") do |config|
  # Global VM settings
  config.vm.box_check_update = true
  config.ssh.insert_key = true

  # disable default synced folder
  config.vm.synced_folder ".", "/vagrant", disabled: true
  
  # Create the network before any VM operations
  config.trigger.before :up do |trigger|
    trigger.name = "Create libvirt network"
    trigger.ruby do
      # Generate and write network XML to temporary file
      require 'tempfile'
      temp_file = Tempfile.new(['network', '.xml'])
      temp_file.write(generate_network_xml(NETWORK_CONFIG, NODES))
      temp_file.close

      # Check if network exists
      network_exists = system("sudo virsh net-list --all | grep -q #{NETWORK_CONFIG[:name]}")
      
      # if network_exists
      #   # Stop and delete existing network
      #   puts "Removing existing network..."
      #   system("sudo virsh net-destroy #{NETWORK_CONFIG[:name]}")
      #   system("sudo virsh net-undefine #{NETWORK_CONFIG[:name]}")
      # end

      unless network_exists
        # Creating and start the network
        puts "Creating new network..."
        system("sudo virsh net-define #{temp_file.path}")
        system("sudo virsh net-start #{NETWORK_CONFIG[:name]}")
        system("sudo virsh net-autostart #{NETWORK_CONFIG[:name]}")
      end

      # Clean up temporary file
      temp_file.unlink
    end
  end

  # Print configuration summary
  config.trigger.before :up do |trigger|
    trigger.info = "Configuring environment for #{NUM_STUDENTS} students"
  end

  # Libvirt provider configuration
  config.vm.provider "libvirt" do |v|
    v.cpus = NODE_CPUS
    v.memory = NODE_MEMORY
    v.mgmt_attach = false
    v.machine_virtual_size = 10
  end

  NODES.each do |node|
    config.vm.define node.role do |n|
      n.vm.box = node.box
      n.vm.hostname = node.role
      n.vm.network "private_network",
        mac: node.mac,
        libvirt__network_name: NETWORK_CONFIG[:name],
        libvirt__forward_mode: "nat",
        libvirt__dhcp_enabled: true,
        auto_config: false

      # Run Ansible playbook
      n.vm.provision "ansible" do |ansible|
        ansible.playbook = "basicvm.yml"
        ansible.compatibility_mode = "2.0"
      end
    end
  end
end