# -*- mode: ruby -*-
# vi: set ft=ruby :

# =======================
# CONFIGURABLE PARAMETERS
# =======================

# VM Configuration
VM_CONFIG = {
  cpus: (ENV['VM_CPUS'] || '2').to_i,
  memory: (ENV['VM_MEMORY'] || '1024').to_i,
  disk_size: (ENV['VM_DISK_SIZE'] || '10').to_i,
  box: ENV['VM_BOX'] || "debian/bookworm64"
}

# Network Configuration
NET_CONFIG = {
  base_subnet: ENV['NET_BASE_SUBNET'] || "192.198",  # Base network segment
  bridge_prefix: (ENV['NET_BRIDGE_PREFIX'] || '100').to_i, 
  start_subnet: (ENV['NET_START_SUBNET'] || '254').to_i,  # First subnet (counts down)
  subnet_mask: ENV['NET_SUBNET_MASK'] || "255.255.255.0"
}

# Docker Configuration
DOCKER_CONFIG = {
  registry_host: ENV['DOCKER_REGISTRY_HOST'] || "localhost:5000",
  docker_network: ENV['DOCKER_NETWORK'] || "10.128.0.0/9"
}

# Student Configuration
STUDENT_CONFIG = {
  count: (ENV['NUM_STUDENTS'] || '1').to_i,
  start_index: (ENV['STUDENT_START_INDEX'] || '2').to_i,  # First student number
  vms_per_student: (ENV['VMS_PER_STUDENT'] || '1').to_i,
  naming_format: ENV['STUDENT_FORMAT'] || "student%02d-vm%d" # Format string for VM names
}

# Ansible Configuration
ANSIBLE_CONFIG = {
  enabled: (ENV['USE_ANSIBLE'] || 'true') == 'true',
  playbook: ENV['ANSIBLE_PLAYBOOK'] || "basicvm.yml",
  compat_mode: ENV['ANSIBLE_COMPAT_MODE'] || "2.0"
}

# =================
# VALIDATION CHECKS
# =================

MAX_STUDENTS = 50
MAX_VMS_PER_STUDENT = 8

if STUDENT_CONFIG[:count] < 1 || STUDENT_CONFIG[:count] > MAX_STUDENTS
  puts "Error: Number of students must be between 1 and #{MAX_STUDENTS}"
  exit 1
end

if STUDENT_CONFIG[:vms_per_student] < 1 || STUDENT_CONFIG[:vms_per_student] > MAX_VMS_PER_STUDENT
  puts "Error: VMs per student must be between 1 and #{MAX_VMS_PER_STUDENT}"
  exit 1
end

# =====================
# INFRASTRUCTURE MODELS
# =====================

# Define a Node class to encapsulate node properties
class Node
  attr_reader :role, :box, :mac, :ip, :network_name, :student_num, :vm_num
  
  def initialize(role, box, mac, ip, network_name, student_num, vm_num)
    @role = role
    @box = box
    @mac = mac
    @ip = ip
    @network_name = network_name
    @student_num = student_num
    @vm_num = vm_num
  end

  def to_dhcp_entry
    %(<host mac='#{@mac}' name='#{@role}' ip='#{@ip}'/>)
  end
end

# Network configuration generator
class NetworkConfig
  attr_reader :name, :bridge, :mac, :ip, :netmask, :dhcp_range
  
  def initialize(subnet_index, vm_num, config)
    @subnet_index = subnet_index
    @vm_num = vm_num
    @name = "vm#{vm_num}net"
    
    interface = subnet_index*10
    @bridge = "virbr#{config[:bridge_prefix] + interface}"
    
    # Fixed: Generate MAC address with both parameters
    @mac = generate_mac(@subnet_index, @vm_num)
    
    # Calculate subnet from the base parameters
    # For VM1 use subnet 254, VM2 use 253, etc.
    subnet_num = config[:start_subnet] - (vm_num - 1)
    @ip = "#{config[:base_subnet]}.#{subnet_num}.1"
    @netmask = config[:subnet_mask]
    
    @dhcp_range = {
      start: "#{config[:base_subnet]}.#{subnet_num}.2",
      end: "#{config[:base_subnet]}.#{subnet_num}.253"
    }
  end
  
  private
  
  # Fixed: Explicitly pass both parameters
  def generate_mac(subnet_index, vm_num)
    # Ensures unique MAC for each network
    format("52:54:00:AA:%02X:%02X", subnet_index, vm_num)
  end
end

# ===================
# GENERATOR FUNCTIONS
# ===================

# Node generator
def generate_nodes(student_config, vm_config, net_config)
  nodes = []
  
  (1..student_config[:count]).each do |student_idx|
    student_num = student_idx + student_config[:start_index] - 1
    
    (1..student_config[:vms_per_student]).each do |vm_num|
      # Calculate subnet index - different for each VM number
      subnet_index = vm_num - 1
      
      # Calculate the subnet number (254 for VM1, 253 for VM2, etc.)
      subnet_num = net_config[:start_subnet] - (vm_num - 1)
      
      # Generate unique information for this VM
      role = format(student_config[:naming_format], student_num, vm_num)
      box = vm_config[:box]
      
      # MAC addresses should be unique across all VMs
      # First byte identifies the student, second byte identifies the VM number
      mac = format("52:54:00:%02X:%02X:%02X", student_idx, vm_num, 0xAA)
      
      # IP address: use student index for the host part
      # This way each student's VM1 is on the 254 subnet, VM2 on 253, etc.
      ip = "#{net_config[:base_subnet]}.#{subnet_num}.#{2 + (student_idx - 1)}"
      
      # Network name is based on VM number
      network_name = "vm#{vm_num}net"
      
      nodes << Node.new(role, box, mac, ip, network_name, student_num, vm_num)
    end
  end
  
  nodes
end

# Generate network XML from configuration
def generate_network_xml(network_config, nodes)
  # Filter nodes for this specific network
  network_nodes = nodes.select { |node| node.network_name == network_config.name }
  
  <<-EOF
<network>
  <name>#{network_config.name}</name>
  <forward mode='nat'>
    <nat>
      <port start='1024' end='65535'/>
    </nat>
  </forward>
  <bridge name='#{network_config.bridge}' stp='on' delay='0'/>
  <mac address='#{network_config.mac}'/>
  <ip address='#{network_config.ip}' netmask='#{network_config.netmask}'>
    <dhcp>
      <range start='#{network_config.dhcp_range[:start]}' end='#{network_config.dhcp_range[:end]}'/>
      #{network_nodes.map(&:to_dhcp_entry).join("\n      ")}
    </dhcp>
  </ip>
</network>
  EOF
end

# ======================
# GENERATE INFRASTRUCTURE
# ======================

# Generate networks - one per VM type
NETWORKS = (1..STUDENT_CONFIG[:vms_per_student]).map do |vm_num|
  NetworkConfig.new(vm_num - 1, vm_num, NET_CONFIG)
end

# Generate all nodes
NODES = generate_nodes(STUDENT_CONFIG, VM_CONFIG, NET_CONFIG)

# Print summary of the configuration
puts "\nNetwork and VM Configuration:"
puts "-----------------------------"
NETWORKS.each do |network|
  vm_num = network.name.gsub('vm', '').gsub('net', '')
  subnet_num = NET_CONFIG[:start_subnet] - (vm_num.to_i - 1)
  puts "Network for VM#{vm_num}: #{network.name} (#{NET_CONFIG[:base_subnet]}.#{subnet_num}.0/24)"
end

puts "\nNode assignments:"
NODES.each do |node|
  puts "  #{node.role}: #{node.ip} (#{node.network_name}) [MAC: #{node.mac}]"
end
puts "\n"

# ==============
# VAGRANT CONFIG
# ==============

Vagrant.configure("2") do |config|
  # Global VM settings
  config.vm.box_check_update = true
  config.ssh.insert_key = true

  # disable default synced folder
  config.vm.synced_folder ".", "/vagrant", disabled: true
  
  # Create networks only when needed (up command)
  if ARGV.include?('up') || ARGV.include?('reload')
    config.trigger.before :up do |trigger|
      trigger.name = "Create libvirt networks"
      trigger.ruby do
        require 'tempfile'

        # Only process if there are no arguments or the VMs mentioned are in our NODES
        should_create_networks = ARGV.length <= 2 || 
                                ARGV[1..-1].any? do |arg| 
                                  next if arg.start_with?('-')
                                  NODES.any? { |node| node.role == arg }
                                end

        if should_create_networks  
          # Check which networks need to be created or updated
          networks_to_process = NETWORKS.select do |network|
            # Process if network doesn't exist or force update all networks
            true # Changed to always process all networks to ensure consistency
          end
          
          if networks_to_process.empty?
            puts "All required networks already exist. Skipping network creation."
          else
            puts "Creating or updating #{networks_to_process.size} network(s)..."
            
            networks_to_process.each do |network_config|
              # Generate and write network XML to temporary file
              temp_file = Tempfile.new(['network', '.xml'])
              temp_file.write(generate_network_xml(network_config, NODES))
              temp_file.close

              # First try to gracefully stop and undefine the network if it exists
              network_exists = system("sudo virsh net-list --all | grep -q #{network_config.name}")
              
              if network_exists
                # Update the network if it exists - force destroy and undefine
                puts "Updating existing network #{network_config.name}..."
                system("sudo virsh net-destroy #{network_config.name} 2>/dev/null")
                system("sudo virsh net-undefine #{network_config.name} 2>/dev/null")
              end
              
              # Create and start the network
              puts "Creating network #{network_config.name}..."
              system("sudo virsh net-define #{temp_file.path}")
              system("sudo virsh net-start #{network_config.name}")
              system("sudo virsh net-autostart #{network_config.name}")
              
              # Add a sleep to ensure the network is fully initialized
              puts "Waiting for network #{network_config.name} to initialize..."
              sleep 3

              # Clean up temporary file
              temp_file.unlink
            end
          end
        else
          puts "Skipping network creation for specific VM commands"
        end
      end
    end
  end

  # Print configuration summary
  config.trigger.before :up do |trigger|
    trigger.info = <<-EOF
    CTF Environment Configuration:
    -----------------------------
    Students: #{STUDENT_CONFIG[:count]} (starting at #{STUDENT_CONFIG[:start_index]})
    VMs per student: #{STUDENT_CONFIG[:vms_per_student]}
    Total VMs: #{STUDENT_CONFIG[:count] * STUDENT_CONFIG[:vms_per_student]}
    VM specs: #{VM_CONFIG[:cpus]} CPUs, #{VM_CONFIG[:memory]}MB RAM, #{VM_CONFIG[:disk_size]}GB disk
    Base image: #{VM_CONFIG[:box]}
    Docker registry: #{DOCKER_CONFIG[:registry_host]}
    Docker network: #{DOCKER_CONFIG[:docker_network]}
    EOF
  end

  # Libvirt provider configuration
  config.vm.provider "libvirt" do |v|
    v.cpus = VM_CONFIG[:cpus]
    v.memory = VM_CONFIG[:memory]
    v.mgmt_attach = false
    v.machine_virtual_size = VM_CONFIG[:disk_size]
  end

  # Define each VM
  NODES.each do |node|
    config.vm.define node.role do |n|
      n.vm.box = node.box
      n.vm.hostname = node.role
      n.vm.network "private_network",
        mac: node.mac,
        libvirt__network_name: node.network_name,
        libvirt__forward_mode: "nat",
        libvirt__dhcp_enabled: true,
        ip: node.ip,  # Set static IP directly
        auto_config: true  # Try to auto-configure in the guest

      # Run Ansible playbook if enabled
      if ANSIBLE_CONFIG[:enabled]
        n.vm.provision "ansible" do |ansible|
          ansible.playbook = ANSIBLE_CONFIG[:playbook]
          ansible.compatibility_mode = ANSIBLE_CONFIG[:compat_mode]
          ansible.extra_vars = {
            student_id: "student#{format('%02d', node.student_num)}",
            vm_id: "vm#{node.vm_num}",
            student_index: node.student_num,
            vm_index: node.vm_num,
            ip_address: node.ip,
            network_name: node.network_name,
            # Add Docker configuration variables
            registry_host: DOCKER_CONFIG[:registry_host],
            docker_network: DOCKER_CONFIG[:docker_network]
          }
        end
      end
    end
  end
  
  # Cleanup networks only when destroy command is used
  if ARGV.include?('destroy')
    config.trigger.after :destroy do |trigger|
      trigger.name = "Cleanup libvirt networks"
      trigger.ruby do
        # Only clean up if all VMs are being destroyed
        if ARGV.include?('--force') || ARGV.length <= 2
          puts "Cleaning up networks..."
          
          NETWORKS.each do |network_config|
            network_exists = system("sudo virsh net-list --all | grep -q #{network_config.name}")
            
            if network_exists
              # Check if any VM is still using this network
              vms_using_network = `sudo virsh list --all | grep -v "^Id" | grep -v "^\-\-" | awk '{print $2}'`.split("\n")
              network_in_use = vms_using_network.any? do |vm|
                xml = `sudo virsh dumpxml #{vm} 2>/dev/null`
                xml.include?("<source network='#{network_config.name}'")
              end
              
              unless network_in_use
                puts "Destroying network #{network_config.name}..."
                system("sudo virsh net-destroy #{network_config.name}")
                system("sudo virsh net-undefine #{network_config.name}")
              else
                puts "Network #{network_config.name} still in use by other VMs - not destroying"
              end
            end
          end
        end
      end
    end
  end
end